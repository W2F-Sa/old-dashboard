  "logging": {
    "log_level": "info",
    "max_log_size": "10MB",
    "log_rotation": true,
    "remote_logging": false,
    "syslog_server": ""
  },
  "performance": {
    "cpu_limit": 80,
    "memory_limit": 512,
    "disk_usage_warning": 85,
    "temperature_warning": 70,
    "auto_restart_on_error": true
  }
